# ─── Resend (envoi d'emails) ────────────────────────────────
# Créez un compte sur https://resend.com et générez une clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email professionnel qui reçoit les demandes de devis
CONTACT_EMAIL=contact@vertnature.fr

# Domaine de votre site (sans slash final) – utilisé pour les emails
NEXT_PUBLIC_SITE_URL=https://www.vertnature.fr

# ─── Optionnel : Rate limiting (Redis) ──────────────────────
# Si vous déployez sur Vercel avec Upstash, ajoutez :
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
